# Google Search Console — Step 1 (scripts/gsc_pull.js)
# Copy to .env and fill in. Never commit your real .env or key file.

# The property as registered in Search Console.
#   Domain property:  sc-domain:cited.example
#   URL-prefix property: https://cited.example/
GSC_SITE_URL="sc-domain:cited.example"

# Absolute path to your Google service-account JSON key.
# The service account's email must be added as a user on the GSC property.
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account-key.json"
